# querymind-schema-service/.env.example
# Copy to .env and fill in values before running.

# HTTP server port (health check only)
PORT=8001

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# RabbitMQ connection URL
AMQP_URL=amqp://querymind:querymind_pass@localhost:5672/

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Schema cache TTL in seconds (default: 1 hour)
SCHEMA_CACHE_TTL=3600

# Celery beat refresh interval in seconds (default: 55 minutes)
CACHE_REFRESH_INTERVAL=3300

# SQLAlchemy connection pool settings
DB_POOL_SIZE=5
DB_POOL_TIMEOUT=30
